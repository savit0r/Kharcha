# Mobile API Configuration
# Replace with your local machine's LAN IP when using a physical device with Expo Go
# Find with: ipconfig (Windows) or ifconfig (Mac/Linux)
API_BASE_URL=http://192.168.x.x:3000/api

# For emulator/simulator you can use:
# Android emulator: http://10.0.2.2:3000/api
# iOS simulator:    http://localhost:3000/api
